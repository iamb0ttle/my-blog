---
import siteConfig from "../site.config";
import Hamburger from "./Hamburger.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import SiteIdentity from "./SiteIdentity.astro";
import NavLinks from "./NavLinks.astro";
import { withBase } from "../utils/helpers";
const { activePage } = Astro.props;
---

<header>
  <nav class="font-light w-full">
    <a href={withBase("/")}><SiteIdentity /></a>
    <div class="hidden sm:flex sm:gap-8">
      <NavLinks activePage={activePage} links={siteConfig.headerNavLinks} />
    </div>
    <ThemeSwitcher />
    <Hamburger />
  </nav>
  <div
    id="mobile-links"
    class="font-light animated hidden w-full"
    aria-label="Mobile navigation"
  >
    <button class="close-menu self-end" type="button" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
    <NavLinks
      activePage={activePage}
      links={siteConfig.headerNavLinks}
      isMobileLink={true}
    />
  </div>
</header>
<script is:inline>
  let closeTimer = null;

  const getMobileLinks = () => document.querySelector("#mobile-links");

  const openMenu = () => {
    const mobileLinks = getMobileLinks();
    if (!mobileLinks) {
      return;
    }

    if (closeTimer) {
      window.clearTimeout(closeTimer);
      closeTimer = null;
    }

    mobileLinks.classList.remove("hidden", "slideOutUp");
    mobileLinks.classList.add("expanded", "slideInDown");
  };

  const closeMenu = () => {
    const mobileLinks = getMobileLinks();
    if (!mobileLinks) {
      return;
    }

    if (closeTimer) {
      window.clearTimeout(closeTimer);
      closeTimer = null;
    }

    mobileLinks.classList.remove("slideInDown");
    mobileLinks.classList.add("slideOutUp");

    closeTimer = window.setTimeout(() => {
      const currentMobileLinks = getMobileLinks();
      if (!currentMobileLinks) {
        closeTimer = null;
        return;
      }

      currentMobileLinks.classList.add("hidden");
      currentMobileLinks.classList.remove("expanded", "slideOutUp");
      closeTimer = null;
    }, 180);
  };

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) {
      return;
    }

    if (event.target.closest("#hamburger-menu")) {
      openMenu();
      return;
    }

    if (
      event.target.closest(".close-menu") ||
      event.target.closest("#mobile-links a")
    ) {
      closeMenu();
    }
  });

  document.addEventListener("swup:visit:start", closeMenu);
  document.addEventListener("swup:page:view", closeMenu);
</script>

<style>
  @media (orientation: portrait) {
    #mobile-links.expanded {
      align-items: end;
      background-color: #0000007a;
      backdrop-filter: blur(72px);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: start;
      position: static;
      z-index: 0;
      opacity: 1;
      margin-top: 0.5rem;
      padding: 0.75rem 1rem 1rem;
      width: 100%;
      max-height: none;
      overflow: visible;
      border-bottom-left-radius: 0.5rem;
      border-bottom-right-radius: 0.5rem;
    }

    html.light #mobile-links.expanded {
      background-color: #ffffff6a;
    }
  }

  .close-menu {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 0;
    background: transparent;
    color: inherit;
    font-size: 1.25rem;
    line-height: 1;
    padding: 0.25rem;
  }
</style>
