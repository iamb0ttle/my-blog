---
import MainLayout from "../layouts/MainLayout.astro";
import { withBase } from "../utils/helpers";
import SpaceKeyboard from "../components/SpaceKeyboard.astro";
import siteConfig from "../site.config";
---

<MainLayout activePage="404" pageTitle={siteConfig.title + " | 404"}>
  <div class="flex flex-col items-center justify-center page-content">
    <h1 class="sigmar-ff">404</h1>
    <div
      class="cover-img w-full max-w-[400px] h-[240px] rounded-4xl border border-gray-500/40 bg-gradient-to-br from-gray-900/60 via-gray-900/20 to-gray-900/0 my-6"
      aria-hidden="true"
    />
    <p>페이지를 찾을 수 없습니다.</p>
    <p>
      주소를 확인하거나 <a
        class="font-medium underline"
        href={withBase("/")}>홈으로 이동</a
      >
    </p>
    <SpaceKeyboard />
  </div>
</MainLayout>
